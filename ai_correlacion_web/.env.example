# Copia para .env. Não commits .env (gitignore).

# --- Teste/produção rápida sem OAuth (recomendado enquanto não configuras login) ---
# Servidor: AUTH_MODE=none
# Build Vite: VITE_AUTH_MODE=none
# Só precisas de JWT_SECRET + DATABASE_URL em produção. A app trata-te como admin.
AUTH_MODE=none
VITE_AUTH_MODE=none

# --- Modo WebDev (Cursor / template) ---
# AUTH_MODE=webdev
# OAUTH_SERVER_URL=http://localhost:9999
# VITE_OAUTH_PORTAL_URL=
# VITE_APP_ID=

# --- Modo Google/Microsoft (OIDC) ---
# AUTH_MODE=oidc
# VITE_AUTH_MODE=oidc
# PUBLIC_APP_URL=https://<serviço>.onrender.com
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common

# Base
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/NOME_BD
# Producao (Postgres alojado): forca ssl na URL do drizzle/ pg se nao tiveres sslmode na string
# DATABASE_SSL=true
JWT_SECRET=gera-uma-string-longa-aleatoria
OWNER_OPEN_ID=

# Em produção o arranque tenta drizzle-kit push se faltarem "users"/"analysisJobs" (desliga com SKIP_DB_AUTO_PUSH=1).
# Manual: cd ai_correlacion_web && pnpm db:push
# SKIP_DB_AUTO_PUSH=1

# Opcional: ficheiros temporários (7z, extração, uploads multipart legados)
# Linux/Render: por defeito em /tmp/...; disco do contentor costuma ser < 1 GB — lotes muito grandes podem dar ENOSPC
# CONTRADEF_WORK_TMP=
# CONTRADEF_REDUCE_LOGS_TMP=   # destino do modo multipart quando não há object storage (Forge)
# CONTRADEF_PARSE_YIELD_EVERY=4096   # ceder o event loop a cada N linhas ao reduzir logs muito grandes (predef.: 4096)
#
# Debug: no browser, `localStorage.setItem("contradef_reduce_logs_debug", "1")` + recarregar; com isto=1, cada
# `analysis.detail` inclui `serverProcessDebug` (memória do processo, RAM da VM, load, disco no CONTRADEF_WORK_TMP).
# CONTRADEF_SERVER_DEBUG=1

# Copia para .env e preenche. Não commits .env (está no .gitignore).

# --- Modo A: WebDev (Cursor / template) — AUTH_MODE=webdev (ou omite) ---
# Callback no painel: https://<serviço>.onrender.com/api/oauth/callback
AUTH_MODE=webdev
OAUTH_SERVER_URL=http://localhost:9999
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=

# --- Modo B: Google / Microsoft nativos — AUTH_MODE=oidc + credenciais abaixo ---
# No build: VITE_AUTH_MODE=oidc. Em produção: PUBLIC_APP_URL=https://<serviço>.onrender.com (sem barra final).
# Regista redirect URIs exactos:
#   .../api/oauth/callback/google
#   .../api/oauth/callback/microsoft
# AUTH_MODE=oidc
# VITE_AUTH_MODE=oidc
# PUBLIC_APP_URL=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common

# Base
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/NOME_BD
JWT_SECRET=gera-uma-string-longa-aleatoria
# Admin (opcional): em oidc, OWNER_OPEN_ID = hash SHA-256 do par provider|sub (ver código) em 64 hex
OWNER_OPEN_ID=
